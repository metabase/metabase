{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "build",
    "noEmit": true,
    "baseUrl": "./",
    "rootDir": "..",
    "types": [
      "cypress",
      "@testing-library/cypress",
      "cypress-real-events",
      "@cypress/grep",
      "../enterprise/frontend/src/embedding-sdk-shared/types/globals.d.ts"
    ],
    "paths": {
      "e2e/*": ["./*"],
      "@metabase/embedding-sdk-react": [
        "../enterprise/frontend/src/embedding-sdk-package/index.ts"
      ],
      "@metabase/embedding-sdk-react/data-app": [
        "../enterprise/frontend/src/embedding-sdk-package/data-app.ts"
      ],
      "@metabase/embedding-sdk-react/data-app-dev": [
        "../enterprise/frontend/src/embedding-sdk-package/data-app-dev.ts"
      ],
      // The data-app dev preview (toolbar + diagnostics feed) is only reachable
      // from source — its internals aren't on the package's public barrel.
      // Mirrors the webpack `embedding-sdk-package` alias so component specs can
      // import it (e.g. data-apps/diagnostics-toolbar).
      "embedding-sdk-package/*": [
        "../enterprise/frontend/src/embedding-sdk-package/*"
      ],
      "*": ["../frontend/src/*"]
    }
  },
  "include": ["**/*"],
  // Data-app fixtures are standalone SDK apps (built by Vite, typechecked by
  // their own tsconfig) — not part of the e2e TS program. Including them pulls
  // SDK source outside this project's rootDir.
  "exclude": ["support/assets/data-apps"]
}
