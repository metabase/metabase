{
  "delete": {
    "description": "Deletes a collection permanently",
    "operationId": "delete-api-collection-id",
    "parameters": [
      {
        "description": "value must be an integer greater than zero.",
        "in": "path",
        "name": "id",
        "required": true,
        "schema": {
          "minimum": 1,
          "type": "integer"
        }
      }
    ],
    "responses": {
      "2XX": {
        "description": "Successful response"
      },
      "4XX": {
        "description": "Client error response"
      },
      "5XX": {
        "description": "Server error response"
      }
    },
    "summary": "DELETE /api/collection/{id}",
    "tags": [
      "/api/collection"
    ]
  },
  "get": {
    "description": "Fetch a specific Collection with standard details added",
    "operationId": "get-api-collection-id",
    "parameters": [
      {
        "in": "path",
        "name": "id",
        "required": true,
        "schema": {
          "anyOf": [
            {
              "description": "value must be an integer greater than zero.",
              "minimum": 1,
              "type": "integer"
            },
            {
              "description": "String must be a valid 21-character NanoID string.",
              "pattern": "^[A-Za-z0-9_\\-]{21}$",
              "type": "string"
            }
          ]
        }
      }
    ],
    "responses": {
      "2XX": {
        "description": "Successful response"
      },
      "4XX": {
        "description": "Client error response"
      },
      "5XX": {
        "description": "Server error response"
      }
    },
    "summary": "GET /api/collection/{id}",
    "tags": [
      "/api/collection"
    ]
  },
  "put": {
    "description": "Modify an existing Collection, including archiving or unarchiving it, or moving it.",
    "operationId": "put-api-collection-id",
    "parameters": [
      {
        "description": "value must be an integer greater than zero.",
        "in": "path",
        "name": "id",
        "required": true,
        "schema": {
          "minimum": 1,
          "type": "integer"
        }
      }
    ],
    "requestBody": {
      "content": {
        "application/json": {
          "schema": {
            "properties": {
              "archived": {
                "default": false,
                "oneOf": [
                  {
                    "type": "boolean"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "authority_level": {
                "oneOf": [
                  {
                    "enum": [
                      "official"
                    ],
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "description": {
                "oneOf": [
                  {
                    "minLength": 1,
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "name": {
                "oneOf": [
                  {
                    "minLength": 1,
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "parent_id": {
                "oneOf": [
                  {
                    "description": "value must be an integer greater than zero.",
                    "minimum": 1,
                    "type": "integer"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "type": {
                "oneOf": [
                  {
                    "enum": [
                      "remote-synced"
                    ],
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              }
            },
            "required": [
              "archived"
            ],
            "type": "object"
          }
        }
      }
    },
    "responses": {
      "2XX": {
        "description": "Successful response"
      },
      "4XX": {
        "description": "Client error response"
      },
      "5XX": {
        "description": "Server error response"
      }
    },
    "summary": "PUT /api/collection/{id}",
    "tags": [
      "/api/collection"
    ]
  }
}