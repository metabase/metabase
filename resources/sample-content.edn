 :documents
 [{:archived false,
   :collection_position 1,
   :collection_id "HyB3nRtqb7pBPhFG26evI",
   :name "Who's Buying Our Stuff?",
   :creator_id "internal@metabase.com",
   :content_type "application/json+vnd.prose-mirror",
   :updated_at "2026-03-05T20:16:14.289671Z",
   :document
   {:type "doc",
    :content
    [{:type "paragraph",
      :attrs {:_id "800633bf-2e9c-fb30-7729-6423a69995b1"},
      :content
      [{:type "text",
        :text "Every order tells a story — but the really interesting stories emerge when you zoom out and look at "}
       {:type "text", :marks [{:type "italic"}], :text "who"}
       {:type "text", :text " is ordering, "}
       {:type "text", :marks [{:type "italic"}], :text "where"}
       {:type "text", :text " they are, and "}
       {:type "text", :marks [{:type "italic"}], :text "how"}
       {:type "text",
        :text
        " they found us. This document digs into our customer base: who they are, where they come from, and what they like to buy."}]}
     {:type "horizontalRule"}
     {:type "heading",
      :attrs {:level 2, :_id "0a0d7843-82c0-aa2f-4eed-c62db24dc79f"},
      :content [{:type "text", :text "How Big Is Our Customer Base?"}]}
     {:type "paragraph",
      :attrs {:_id "a6277b4a-ed2f-c134-c71e-d381154ae840"},
      :content
      [{:type "text", :text "Let's start with the basics. Here's how our customer count has grown since launch."}]}
     {:type "resizeNode",
      :attrs {:height 442, :minHeight 280},
      :content
      [{:type "cardEmbed",
        :attrs
        {:id [{:model "Card", :id "MtZp0RQ1a95mSF9HXOldG"}],
         :name "Customer signups over time",
         :_id "a3b4c3ed-355c-5db7-c7c3-cb3a4200bf2d"}}]}
     {:type "paragraph",
      :attrs {:_id "1c930d37-4253-ac66-19dc-cd1df1e2f6d1"},
      :content
      [{:type "text",
        :text "We've been adding customers at a steady clip. But raw growth doesn't tell us much — let's break down "}
       {:type "text", :marks [{:type "italic"}], :text "who"}
       {:type "text", :text " these people actually are."}]}
     {:type "horizontalRule"}
     {:type "heading",
      :attrs {:level 2, :_id "691fc28e-e748-e7be-1779-f400eefce59e"},
      :content [{:type "text", :text "Where Do Our Customers Come From?"}]}
     {:type "paragraph",
      :attrs {:_id "06277e35-12a7-2a78-2df4-a492965a5e1c"},
      :content
      [{:type "text",
        :text
        "We acquire customers through five channels: Google, Facebook, Twitter, Organic, and Affiliate. The mix matters — it tells us where our marketing dollars are working hardest."}]}
     {:type "resizeNode",
      :attrs {:height 442, :minHeight 280},
      :content
      [{:type "cardEmbed",
        :attrs
        {:id [{:model "Card", :id "Vv4a25xNr-1yuFrGN9E7o"}],
         :name "Customers by acquisition channel",
         :_id "18924051-a181-f971-5abe-1eb478a01e7c"}}]}
     {:type "paragraph",
      :attrs {:_id "62714510-aba9-80de-f05d-5c490d8662cb"},
      :content
      [{:type "text", :text "Now here's the question that actually matters for budget allocation: "}
       {:type "text", :marks [{:type "bold"}], :text "do different channels bring in different quality customers?"}
       {:type "text", :text " Let's look at average order value by acquisition source."}]}
     {:type "resizeNode",
      :attrs {:height 442, :minHeight 280},
      :content
      [{:type "cardEmbed",
        :attrs
        {:id [{:model "Card", :id "f-Rjeh3cxKy19NSlAAxmD"}],
         :name "Average Order Total by Source",
         :_id "adfe60c0-cbaa-7b04-2cb4-222165c3bcc3"}}]}
     {:type "blockquote",
      :attrs {:_id "1a40382e-7b0c-e778-8a19-161c008d7da4"},
      :content
      [{:type "paragraph",
        :attrs {:_id "0c5c8f78-2349-1414-9c99-9e74c4bbb01b"},
        :content
        [{:type "text",
          :text
          "If one channel is bringing in higher value customers, we should be willing to pay more per acquisition there."}]}]}
     {:type "horizontalRule"}
     {:type "heading",
      :attrs {:level 2, :_id "f2742313-967b-b1b2-a80c-b4b7ed90bb89"},
      :content [{:type "text", :text "Customer Age"}]}
     {:type "paragraph",
      :attrs {:_id "1b70593d-ede8-8746-729f-47766a9c357d"},
      :content [{:type "text", :text "Our customers span a wide age range. Here's the distribution:"}]}
     {:type "resizeNode",
      :attrs {:height 442, :minHeight 280},
      :content
      [{:type "cardEmbed",
        :attrs
        {:id [{:model "Card", :id "0ARZQCOwyDIShbsojgt7X"}],
         :name "Customer Age Distribution",
         :_id "b5241003-de2f-2eb2-1707-6be06ad6759a"}}]}
     {:type "paragraph",
      :attrs {:_id "bcdcc06d-e717-f20b-e974-b960430dd826"},
      :content
      [{:type "text",
        :text
        "But age alone is just trivia. The real insight is in how spending behavior varies across generations."}]}
     {:type "resizeNode",
      :attrs {:height 442, :minHeight 280},
      :content
      [{:type "cardEmbed",
        :attrs
        {:id [{:model "Card", :id "xQIaIT_6BsSOgvBGMlGcq"}],
         :name "Average spend by age and product category",
         :_id "a779d0bd-0805-8fc0-197e-9ec850210187"}}]}
     {:type "paragraph",
      :attrs {:_id "84f7928f-0aca-6e08-8444-c8ef769f9801"},
      :content [{:type "text", :text "A few things jump out:"}]}
     {:type "paragraph",
      :attrs {:_id "145e3059-d488-9a62-265c-24adb4d67252"},
      :content
      [{:type "text", :text "- "}
       {:type "text", :marks [{:type "bold"}], :text "Younger customers (20s–30s)"}
       {:type "text", :text " skew toward Gadgets and Gizmos — the flashier, tech-forward categories"}]}
     {:type "paragraph",
      :attrs {:_id "925d2f92-f37e-2e11-4d86-731e00fc8ec5"},
      :content
      [{:type "text", :text "- "}
       {:type "text", :marks [{:type "bold"}], :text "Older customers (50s+)"}
       {:type "text", :text " over-index on Doohickeys and Widgets — the practical, utilitarian stuff"}]}
     {:type "paragraph",
      :attrs {:_id "7e09a868-8ccd-1140-b1ff-5f12ad8b50af"},
      :content
      [{:type "text", :text "- "}
       {:type "text", :marks [{:type "bold"}], :text "The 35–45 sweet spot"}
       {:type "text", :text " spends the most overall, across all categories"}]}
     {:type "resizeNode",
      :attrs {:height 442, :minHeight 280},
      :content
      [{:type "cardEmbed",
        :attrs
        {:id [{:model "Card", :id "j5pCohVPTN7Q21h9fMKRN"}],
         :name "Orders by generation and category",
         :_id "0f60d282-01d3-8497-d32f-dbae176d819b"}}]}
     {:type "horizontalRule"}
     {:type "heading",
      :attrs {:level 2, :_id "8efbd06a-1c80-aad8-cded-98b3f170660f"},
      :content [{:type "text", :text "Geography: Coast to coast"}]}
     {:type "paragraph",
      :attrs {:_id "501519d9-3719-b809-2704-ca55fdceb979"},
      :content
      [{:type "text",
        :text "Our customers are spread across all 50 states, but the distribution is far from uniform."}]}
     {:type "resizeNode",
      :attrs {:height 442, :minHeight 280},
      :content
      [{:type "cardEmbed",
        :attrs
        {:id [{:model "Card", :id "h9yneXmygUcvhhm7KpJJX"}],
         :name "Where our customers live",
         :_id "8f7d6dc6-dab9-75a0-2e17-109c7f514515"}}]}
     {:type "paragraph",
      :attrs {:_id "5796bfee-d9d6-1cae-0d6a-359b71084cb3"},
      :content
      [{:type "text",
        :text
        "The coasts dominate, which isn't surprising. But the more interesting question is whether geography correlates with "}
       {:type "text", :marks [{:type "italic"}], :text "what"}
       {:type "text", :text " people buy."}]}
     {:type "resizeNode",
      :attrs {:height 442, :minHeight 280},
      :content
      [{:type "cardEmbed",
        :attrs
        {:id [{:model "Card", :id "XUlRdcYYJGD_BovBtaQBw"}],
         :name "Revenue by state and category",
         :_id "b055568c-da71-bd3b-5228-aa8e5c92688b"}}]}
     {:type "paragraph",
      :attrs {:_id "4e06a25a-e49e-fcc2-0efc-1e378121ca0b"},
      :content
      [{:type "text",
        :text
        "California and New York lead in raw volume, but look at the per-capita spending — some smaller states punch well above their weight."}]}
     {:type "horizontalRule"}
     {:type "heading",
      :attrs {:level 2, :_id "cdb4e6a3-c67b-81eb-9040-85b8280a6004"},
      :content [{:type "text", :text "The Discount Question"}]}
     {:type "paragraph",
      :attrs {:_id "d2301051-069f-1a87-8d86-f44d389e92d7"},
      :content
      [{:type "text",
        :text
        "We offer discounts on some orders. But are we being smart about it? Let's see who's getting discounts and whether they're actually driving more volume."}]}
     {:type "resizeNode",
      :attrs {:height 442, :minHeight 280},
      :content
      [{:type "cardEmbed",
        :attrs
        {:id [{:model "Card", :id "_IYa6C37mm0sxGGWNN7_B"}],
         :name "Discount vs order total",
         :_id "6b6b8fe5-601d-6f4d-463a-fa2515bf3330"}}]}
     {:type "paragraph", :attrs {:_id "bc4739e9-f47e-87f4-3329-07e498ea1679"}}
     {:type "paragraph",
      :attrs {:_id "aac83d88-b5c5-a296-e5e5-4d1a2c446be5"},
      :content
      [{:type "text", :text "Interestingly, discounts "}
       {:type "text", :marks [{:type "bold"}], :text "don't"}
       {:type "text",
        :text
        " seem to strongly correlate with larger order totals. Let's check whether discounted orders come from specific acquisition channels."}]}
     {:type "resizeNode",
      :attrs {:height 442, :minHeight 280},
      :content
      [{:type "cardEmbed",
        :attrs
        {:id [{:model "Card", :id "iBi0G33_uMv9rw3cwXak8"}],
         :name "Discount usage by acquisition channel",
         :_id "fcec52b1-97a6-2a4f-85a2-da4cf245bb8f"}}]}
     {:type "paragraph", :attrs {:_id "0b72be5b-ac31-2c11-f04d-2a3d963ac56e"}}
     {:type "blockquote",
      :attrs {:_id "9ec2e927-ba8d-9f93-ca50-7ad9a249e429"},
      :content
      [{:type "paragraph",
        :attrs {:_id "5b9e529c-83f3-1552-3c20-8726ebada4fc"},
        :content
        [{:type "text", :marks [{:type "bold"}], :text "Key takeaway:"}
         {:type "text",
          :text
          " If discounts aren't lifting AOV or skewing toward a particular channel, we might be leaving margin on the table. Worth revisiting our discounting strategy with the marketing team."}]}]}
     {:type "horizontalRule"}
     {:type "heading",
      :attrs {:level 2, :_id "d165efba-e2de-5ec0-3393-25b93085ec15"},
      :content [{:type "text", :text "What Are People Actually Buying?"}]}
     {:type "paragraph",
      :attrs {:_id "bb49df35-3a15-0fa0-0b84-42805bdf6387"},
      :content [{:type "text", :text "Let's look at our product catalog through the lens of customer behavior."}]}
     {:type "resizeNode",
      :attrs {:height 442, :minHeight 280},
      :content
      [{:type "cardEmbed",
        :attrs
        {:id [{:model "Card", :id "IRIr7nMwXasndvhbGAo9W"}],
         :name "Most popular products",
         :_id "8b65039a-b268-ad67-d193-3764c9fd7206"}}]}
     {:type "paragraph",
      :attrs {:_id "e4418315-2ba5-96db-acde-f4e61b4312ac"},
      :content
      [{:type "text",
        :text "The usual suspects lead — but popularity doesn't mean profitability. Here's revenue per product:"}]}
     {:type "resizeNode",
      :attrs {:height 442, :minHeight 280},
      :content
      [{:type "cardEmbed",
        :attrs
        {:id [{:model "Card", :id "hrxKL1Ap3ysSin3NOvJSQ"}], :name nil, :_id "1a25f493-d5cf-dae3-8c20-30f71eb6e96f"}}]}
     {:type "paragraph",
      :attrs {:_id "7cc6fc92-725f-deab-e57c-f73836edd951"},
      :content
      [{:type "text", :text "And how do customers "}
       {:type "text", :marks [{:type "italic"}], :text "rate"}
       {:type "text", :text " what they're buying?"}]}
     {:type "resizeNode",
      :attrs {:height 442, :minHeight 280},
      :content
      [{:type "cardEmbed",
        :attrs
        {:id [{:model "Card", :id "6XhWAwvG4IbBhbbl4OfNG"}], :name nil, :_id "28f3074e-6336-85e4-ba6e-cab6e3628ec8"}}]}
     {:type "resizeNode",
      :attrs {:height 442, :minHeight 280},
      :content
      [{:type "cardEmbed",
        :attrs
        {:id [{:model "Card", :id "5lvCFm9mc_vEPk8c3AwKt"}],
         :name "Products needing attention",
         :_id "668ae934-a95a-f655-d28e-874bb80d9162"}}]}
     {:type "blockquote",
      :attrs {:_id "f0545465-4946-4a74-539e-af0efc0a264e"},
      :content
      [{:type "paragraph",
        :attrs {:_id "0e4e254e-e031-14f1-21af-88b19ff8d93f"},
        :content
        [{:type "text",
          :text
          "Low ratings + high order volume = a customer satisfaction time bomb. These products need attention."}]}]}
     {:type "horizontalRule"}
     {:type "heading",
      :attrs {:level 2, :_id "54090a93-c332-3d60-4f5d-d281af819847"},
      :content [{:type "text", :text "Customer Loyalty: One-Timers vs. Repeat Buyers"}]}
     {:type "paragraph",
      :attrs {:_id "09a604e2-6270-ccd6-b850-713aa21ad80e"},
      :content [{:type "text", :text "Not all customers are created equal. Let's segment by order frequency."}]}
     {:type "resizeNode",
      :attrs {:height 442, :minHeight 280},
      :content
      [{:type "cardEmbed",
        :attrs
        {:id [{:model "Card", :id "HJciacKmxVKslQWwTc6iC"}],
         :name "How many orders does each customer place?",
         :_id "42b336f0-ba32-f1fb-9bc3-489be39fc595"}}]}
     {:type "paragraph",
      :attrs {:_id "bfc91808-1f74-0224-8fde-e3a3d92bfe87"},
      :content
      [{:type "text",
        :text
        "Most customers have placed multiple orders, which is a healthy sign. But let's look at how repeat buyers differ from one-time purchasers:"}]}
     {:type "resizeNode",
      :attrs {:height 442, :minHeight 280},
      :content
      [{:type "cardEmbed",
        :attrs
        {:id [{:model "Card", :id "d5r8pRNWt2IXaBp4zMLx9"}],
         :name "One-time vs repeat buyers",
         :_id "55311f8b-d4db-0c19-988b-2259d84e1ff6"}}]}
     {:type "paragraph", :attrs {:_id "563b0c5e-0da4-e64e-da16-2298b453760a"}}
     {:type "horizontalRule"}
     {:type "heading",
      :attrs {:level 2, :_id "2d3ac1ba-7d18-c3bd-75c4-d4a2743d921c"},
      :content [{:type "text", :text "Putting It All Together"}]}
     {:type "paragraph",
      :attrs {:_id "5c3f72d7-7e3a-d52f-2827-e90ee3c20176"},
      :content
      [{:type "text", :text "Our strongest customer profile: "}
       {:type "text",
        :marks [{:type "bold"}],
        :text
        "35–45 years old, acquired via Google or Organic search, living on the East or West Coast, buying across multiple product categories, and coming back for repeat purchases."}]}
     {:type "paragraph",
      :attrs {:_id "1c25aee5-aa7d-f374-3707-fb87f899d36e"},
      :content
