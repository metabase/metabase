{
  "printWidth": 80,
  "trailingComma": "all",
  "sortImports": {
    "customGroups": [
      {
        "groupName": "internal-pre-metabase",
        "elementNamePattern": [
          "__support__/**",
          "assets/**",
          "build-configs/**",
          "cljs/**",
          "docs/**",
          "e2e/**",
          "ee-plugins/**",
          "embedding-sdk-bundle/**",
          "embedding-sdk-shared/**",
          "embedding-sdk-package/**"
        ]
      },
      {
        "groupName": "metabase-core",
        "elementNamePattern": ["metabase/**"]
      },
      {
        "groupName": "metabase-scoped",
        "elementNamePattern": ["metabase-*/**", "metabase-*"]
      },
      {
        "groupName": "internal-post-metabase",
        "elementNamePattern": ["sdk-ee-plugins/**"]
      }
    ],
    "groups": [
      ["value-builtin", "type-builtin"],
      ["value-external", "type-external"],
      "internal-pre-metabase",
      { "newlinesBetween": false },
      "metabase-core",
      { "newlinesBetween": false },
      "metabase-scoped",
      { "newlinesBetween": false },
      "internal-post-metabase",
      ["value-parent", "type-parent"],
      ["value-sibling", "type-sibling"],
      ["value-index", "type-index"]
    ],
    "newlinesBetween": true,
    "order": "asc",
    "ignoreCase": false
  }
}
