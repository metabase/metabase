    "parameters": [
      {
        "in": "path",
        "name": "entity",
        "required": true,
        "schema": {
          "enum": [
            "adhoc",
            "field",
            "model",
            "question",
            "segment",
            "table",
            "transform"
          ],
          "type": "string"
        }
      },
      {
        "in": "path",
        "name": "entity-id-or-query",
        "required": true,
        "schema": {
          "$ref": "../components/schemas/metabase.xrays.api.automagic-dashboards.entity-id-or-query.json"
        }
      },
      {
        "in": "query",
        "name": "show",
        "required": false,
        "schema": {
          "oneOf": [
            {
              "anyOf": [
                {
                  "const": "all"
                },
                {
                  "minimum": 0,
                  "type": "integer"
                }
              ]
            },
            {
              "type": "null"
            }
          ]
        }
      }
    ],
    "responses": {
      "2XX": {
        "description": "Successful response"
      },
      "4XX": {
        "description": "Client error response"
      },
      "5XX": {
        "description": "Server error response"
      }
    },
    "summary": "GET /api/automagic-dashboards/{entity}/{entity-id-or-query}",
    "tags": [
      "/api/automagic-dashboards"
    ]
  }
}