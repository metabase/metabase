{
  "delete": {
    "description": "Disable a `User`.  This does not remove the `User` from the DB, but instead disables their account.",
    "operationId": "delete-api-user-id",
    "parameters": [
      {
        "description": "value must be an integer greater than zero.",
        "in": "path",
        "name": "id",
        "required": true,
        "schema": {
          "minimum": 1,
          "type": "integer"
        }
      }
    ],
    "responses": {
      "2XX": {
        "description": "Successful response"
      },
      "4XX": {
        "description": "Client error response"
      },
      "5XX": {
        "description": "Server error response"
      }
    },
    "summary": "DELETE /api/user/{id}",
    "tags": [
      "/api/user"
    ]
  },
  "get": {
    "description": "Fetch a `User`. You must be fetching yourself *or* be a superuser *or* a Group Manager.",
    "operationId": "get-api-user-id",
    "parameters": [
      {
        "description": "value must be an integer greater than zero.",
        "in": "path",
        "name": "id",
        "required": true,
        "schema": {
          "minimum": 1,
          "type": "integer"
        }
      }
    ],
    "responses": {
      "2XX": {
        "description": "Successful response"
      },
      "4XX": {
        "description": "Client error response"
      },
      "5XX": {
        "description": "Server error response"
      }
    },
    "summary": "GET /api/user/{id}",
    "tags": [
      "/api/user"
    ]
  },
  "put": {
    "description": "Update an existing, active `User`.\n  Self or superusers can update user info and groups.\n  Group Managers can only add/remove users from groups they are manager of.",
    "operationId": "put-api-user-id",
    "parameters": [
      {
        "description": "value must be an integer greater than zero.",
        "in": "path",
        "name": "id",
        "required": true,
        "schema": {
          "minimum": 1,
          "type": "integer"
        }
      }
    ],
    "requestBody": {
      "content": {
        "application/json": {
          "schema": {
            "properties": {
              "email": {
                "oneOf": [
                  {
                    "description": "value must be a valid email address.",
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "first_name": {
                "oneOf": [
                  {
                    "minLength": 1,
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "is_data_analyst": {
                "oneOf": [
                  {
                    "type": "boolean"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "is_group_manager": {
                "oneOf": [
                  {
                    "type": "boolean"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "is_superuser": {
                "oneOf": [
                  {
                    "type": "boolean"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "last_name": {
                "oneOf": [
                  {
                    "minLength": 1,
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "locale": {
                "oneOf": [
                  {
                    "description": "String must be a valid two-letter ISO language or language-country code e.g. 'en' or 'en_US'.",
                    "minLength": 1,
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "login_attributes": {
                "oneOf": [
                  {
                    "additionalProperties": {},
                    "type": "object"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "tenant_id": {
                "oneOf": [
                  {
                    "description": "value must be an integer greater than zero.",
                    "minimum": 1,
                    "type": "integer"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "user_group_memberships": {
                "oneOf": [
                  {
                    "items": {
                      "$ref": "../components/schemas/metabase.users.schema.user-group-membership.json"
                    },
                    "type": "array"
                  },
                  {
                    "type": "null"
                  }
                ]
              }
            },
            "type": "object"
          }
        }
      }
    },
    "responses": {
      "2XX": {
        "description": "Successful response"
      },
      "4XX": {
        "description": "Client error response"
      },
      "5XX": {
        "description": "Server error response"
      }
    },
    "summary": "PUT /api/user/{id}",
    "tags": [
      "/api/user"
    ]
  }
}