    {:query
     "SELECT\n\n  CASE WHEN order_count = 1 THEN 'One-time' ELSE 'Repeat' END AS \"Buyer Type\",\n\n  ROUND(AVG(avg_total), 2) AS \"Avg Order Value\",\n\n  COUNT(*) AS \"Customers\"\n\nFROM (\n\n  SELECT\n\n    o.USER_ID,\n\n    COUNT(*) AS order_count,\n\n    AVG(o.TOTAL) AS avg_total\n\n  FROM ORDERS o\n\n  GROUP BY o.USER_ID\n\n) sub\n\nGROUP BY CASE WHEN order_count = 1 THEN 'One-time' ELSE 'Repeat' END;"}},
