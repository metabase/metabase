{{> _header }}
{{#with payload.event_info.details.invitor as |invitor|}}
  <div style="padding-top: 40px; padding-left: 16px; padding-bottom: 96px; padding-right: 16px; box-sizing: border-box; width: 100%; max-width: 600px; background-color: #FFFFFF; border-radius: 24px; border: 1px solid #dcdfe0; margin-top: 32px; margin-left: auto; margin-right: auto;">
    <div style="margin-bottom: 32px; text-align: center; padding-top: 5px; box-sizing: border-box; padding-bottom: 5px;">
      <img style="max-height: 46px; max-width: 100%;" src="{{context.application_logo_url}}" alt="{{context.application_name}} logo" />
    </div>
    <div>
      {{#if payload.custom.invite_target_name}}
        <div style="max-width: 504px; text-align: center; margin-left: auto; margin-right: auto;">
          <h2 style="font-weight: 400; color: #2F3C45; line-height: 36px; margin-top: 0; font-size: 27px;">
            {{#if payload.custom.invite_target_is_dashboard}}
              {{#if invitor.first_name}}
                {{invitor.first_name}} wants to share a {{context.application_name}} dashboard with you
              {{else}}
                A {{context.application_name}} dashboard has been shared with you
              {{/if}}
            {{else}}
              {{#if invitor.first_name}}
                {{invitor.first_name}} wants to share a {{context.application_name}} question with you
              {{else}}
                A {{context.application_name}} question has been shared with you
              {{/if}}
            {{/if}}
          </h2>
        </div>
        <div style="max-width: 504px; text-align: center; margin-left: auto; margin-right: auto;">
          <div style="margin-top: 24px; margin-bottom: 24px;">
            {{#if payload.custom.invite_target_is_dashboard}}
              <svg width="20" height="20" viewBox="0 0 16 16" fill="#509EE3" xmlns="http://www.w3.org/2000/svg" style="vertical-align: middle;"><path d="M4.75 9a.75.75 0 0 0 0 1.5h6.5a.75.75 0 0 0 0-1.5h-6.5zM4 6.25a1 1 0 1 1 2 0 1 1 0 0 1-2 0zM7.75 5.5a.75.75 0 0 0 0 1.5h3.5a.75.75 0 0 0 0-1.5h-3.5z" /><path fill-rule="evenodd" clip-rule="evenodd" d="M1.25 3c0-.966.784-1.75 1.75-1.75h10c.966 0 1.75.784 1.75 1.75v10A1.75 1.75 0 0 1 13 14.75H3A1.75 1.75 0 0 1 1.25 13V3zm1.5 10V3.5h10.5V13a.25.25 0 0 1-.25.25H3a.25.25 0 0 1-.25-.25z" /></svg>
            {{else}}
              <svg width="20" height="20" viewBox="0 0 16 16" fill="#509EE3" xmlns="http://www.w3.org/2000/svg" style="vertical-align: middle;"><path d="M11.5 2.75a.75.75 0 0 1 .75-.75h1a.75.75 0 0 1 .75.75V14h-2.5V2.75zM6.75 8.25c0-.467 0-.701.1-.875a.75.75 0 0 1 .275-.275C7.299 7 7.533 7 8 7s.701 0 .875.1a.75.75 0 0 1 .275.275c.1.174.1.408.1.875V14h-2.5V8.25zM2.75 10a.75.75 0 0 0-.75.75V14h2.5v-3.25a.75.75 0 0 0-.75-.75h-1z" /></svg>
            {{/if}}
            <span style="vertical-align: middle; margin-left: 8px; font-size: 18px; font-weight: 600; color: #2F3C45;">{{payload.custom.invite_target_name}}</span>
          </div>
          <p style="margin-bottom: 32px; line-height: 24px; color: #656F76; font-size: 15px;">
            {{context.application_name}} is a simple and powerful analytics tool that lets you easily ask questions and get answers about your company’s data.
          </p>
        </div>
      {{else}}
        {{#if payload.event_info.object.is_from_setup}}
          <div style="max-width: 504px; text-align: center; margin-left: auto; margin-right: auto;">
            <h2 style="font-weight: 400; color: #2F3C45; line-height: 36px; margin-top: 0; font-size: 27px;">
              {{#if invitor.first_name}}
                {{invitor.first_name}} could use your help setting up {{context.application_name}}
              {{else}}
                You are invited to help setting up {{context.application_name}}
              {{/if}}
            </h2>
          </div>
          <div style="max-width: 504px; text-align: center; margin-left: auto; margin-right: auto;">
            <p style="margin-top: 24px; margin-bottom: 10px; line-height: 24px; color: #656F76; font-size: 15px;">
              {{context.application_name}} is a simple and powerful analytics tool that lets you easily ask questions and get answers about your company’s data.
            </p>
            <p style="margin-bottom: 0; line-height: 24px; color: #656F76; font-size: 15px;">
              {{#if invitor.first_name}}
                Your {{context.application_name}} is up and running, but {{invitor.first_name}} needs you to connect your data. You'll probably need:
              {{else}}
                Your {{context.application_name}} is up and running, but your help is needed to connect data. You'll probably need:
              {{/if}}
            </p>
            <ul style="text-align: left; margin-bottom: 32px; font-size: 15px; margin-top: 20px; padding-left: 30px;">
              <li>Database type (Redshift, Snowflake, etc...)</li>
              <li>Host and port</li>
              <li>Username and password</li>
            </ul>
          </div>
        {{else}}
          <div style="max-width: 504px; text-align: center; margin-left: auto; margin-right: auto;">
            <h2 style="font-weight: 400; color: #2F3C45; line-height: 36px; margin-top: 0; font-size: 27px;">
              {{#if invitor.first_name}}
                {{invitor.first_name}} wants you to join them on {{context.application_name}}
              {{else}}
                You are invited to join {{context.application_name}}
              {{/if}}
            </h2>
          </div>
          <div style="max-width: 504px; text-align: center; margin-left: auto; margin-right: auto;">
            <p style="margin-top: 24px; margin-bottom: 24px; line-height: 24px; color: #656F76; font-size: 15px;">
              {{context.application_name}} is a simple and powerful analytics tool that lets you easily ask questions and get answers about your company’s data.
            </p>
          </div>
        {{/if}}
      {{/if}}
      <div style="padding-right: 0; padding-left: 0; text-align: center; width: 100%;">
        <a
          style="font-size: 15px; padding-top: 16px; padding-bottom: 16px; padding-left: 32px; padding-right: 32px; cursor: pointer; text-decoration: none; font-weight: 700; border-radius: 12px; background-color: #358CD9; color: #fff; line-height: 16px; display: inline-block; margin-left: auto; margin-right: auto; min-width: 200px;"
          href="{{payload.custom.user_invited_join_url}}"
        >Join {{context.application_name}} now</a>
      </div>
      {{#if payload.event_info.object.is_from_setup}}
        <div style="max-width: 504px; margin-left: auto; margin-right: auto; line-height: 24px; color: #656F76; text-align: center;">
          <p style="margin-top: 48px; line-height: 24px; color: #656F76; font-size: 15px;">
            P.S. If you run into any issues, check out our <a style="color: #656F76;" href="https://www.metabase.com/docs/latest/databases/connecting">connection</a> and <a style="color: #656F76;" href="https://www.metabase.com/docs/latest/troubleshooting-guide/db-connection">troubleshooting</a> guides.
          </p>
        </div>
      {{/if}}
    </div>
  </div>
{{/with}}
</div>
</body>
</html>
