{
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": true,
    "filesystem": {
      "allowWrite": [".", "{{pwd}}", "~/.m2", "~/.gitlibs", "~/.deps.clj", "~/.local/state/workmux", "~/.cache/workmux", "{{tmpdir}}", "/tmp"],
      "allowRead": [".", "{{pwd}}", "~/.m2", "~/.gitlibs", "~/.deps.clj", "~/.local/state/workmux", "~/.cache/workmux", "{{tmpdir}}", "/tmp"]
    },
    "excludedCommands": ["docker"],
    "network": {
      "allowLocalBinding": true,
      "allowedDomains": []
    }
  },
  "permissions": {
    "allow": [
      "Edit",
      "Write",
      "Skill",
      "WebFetch(domain:linear.app)",
      "WebFetch(domain:metabase.com)"
    ]
  },
  "skipDangerousModePermissionPrompt": true
}
