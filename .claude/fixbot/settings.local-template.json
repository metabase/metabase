{
  "sandbox": {
    "enabled": true,
    "autoAllow": true,
    "allowUnsandboxedCommands": false,
    "filesystem": {
      "allowWrite": [".", "~/.m2", "~/.gitlibs", "~/.deps.clj", "/tmp"]
    },
    "excludedCommands": ["docker"]
  },
  "permissions": {
    "allow": [
      "Edit",
      "Write",
      "Bash(grep:*)",
      "WebFetch(domain:linear.app)",
      "WebFetch(domain:metabase.com)",
      "Bash(clj-nrepl-eval:*)",
      "Bash(bb:*)",
      "Bash(tmux list-sessions:*)",
      "Bash(tmux capture-pane:*)",
      "Bash(gh search:*)"
    ]
  },
  "skipDangerousModePermissionPrompt": true
}
