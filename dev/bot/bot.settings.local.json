{
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": true,
    "filesystem": {
      "allowWrite": [
        ".",
        "{{pwd}}",
        "~/.m2",
        "~/.gitlibs",
        "~/.deps.clj",
        "~/.local/state/workmux",
        "~/.cache/workmux",
        "{{tmpdir}}",
        "/tmp",
        "/private/tmp",
        "/var/folders",
        "/private/var/folders",
        "~/Library/Caches/ms-playwright",
        "~/Library/Application Support/Google/Chrome"
      ],
      "allowRead": [
        ".",
        "{{pwd}}",
        "~/.m2",
        "~/.gitlibs",
        "~/.deps.clj",
        "~/.local/state/workmux",
        "~/.cache/workmux",
        "{{tmpdir}}",
        "/tmp",
        "/private/tmp",
        "/var/folders",
        "/private/var/folders",
        "~/Library/Caches/ms-playwright",
        "~/Library/Application Support/Google/Chrome"
      ]
    },
    "network": {
      "allowLocalBinding": true,
      "allowAllUnixSockets": true,
      "allowedDomains": [
        "metabase.com",
        "*.metabase.com",
        "*.coredev.metabase.com",
        "repl.coredev.metabase.com",
        "github.com",
        "api.github.com",
        "*.githubusercontent.com",
        "*.blob.core.windows.net",
        "api.linear.app",
        "registry.npmjs.org",
        "*.npmjs.org",
        "*.npmjs.com",
        "nodejs.org",
        "playwright.download.prss.microsoft.com",
        "cdn.playwright.dev",
        "repo1.maven.org",
        "repo.clojars.org",
        "repo.maven.apache.org"
      ]
    }
  },
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Glob",
      "Grep",
      "Write",
      "Skill",
      "Bash(*)",
      "mcp__playwright__*",
      "WebFetch(domain:linear.app)",
      "WebFetch(domain:metabase.com)"
    ]
  },
  "skipDangerousModePermissionPrompt": false
}
