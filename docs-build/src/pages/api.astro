---
// Renders the Scalar viewer for the OpenAPI spec at /api.json (same origin,
// emitted by src/pages/api.json.ts). The spec is regenerated by
// `clojure -M:ee:doc api-documentation` → docs/api.json.
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const scalarVersion = "1.39.1";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>API Reference | Metabase Documentation</title>
    <meta name="description" content="The official API documentation for Metabase." />
    <link rel="icon" type="image/svg+xml" href={`${base}/images/favicon.svg`} />
    <style>
      :root {
        --scalar-font: 'Lato', sans-serif;
      }
      html, body { margin: 0; }
    </style>
  </head>
  <body>
    <script id="api-reference" data-url={`${base}/api.json`}></script>
    <script
      src={`https://cdn.jsdelivr.net/npm/@scalar/api-reference@${scalarVersion}/dist/browser/standalone.min.js`}
    ></script>
    <link
      rel="stylesheet"
      href={`https://cdn.jsdelivr.net/npm/@scalar/api-reference@${scalarVersion}/dist/style.min.css`}
    />
  </body>
</html>
