#: metabase/cache/api.clj:229
msgid "No cache configuration to invalidate."
msgstr "ЩҮЫҢЪҶ ЩҫЫҢЪ©ШұШЁЩҶШҜЫҢ Ъ©ШҙЫҢ ШЁШұШ§ЫҢ ШЁЫҢвҖҢШ§Ш№ШӘШЁШ§Шұ Ъ©ШұШҜЩҶ ЩҲШ¬ЩҲШҜ ЩҶШҜШ§ШұШҜ."

#: metabase/cache/api.clj:227
msgid "Cleared a cached result."
msgid_plural "Cleared {0} cached results."
msgstr[0] "ЫҢЪ© ЩҶШӘЫҢШ¬ЩҮЩ” Ъ©ШҙвҖҢШҙШҜЩҮ ЩҫШ§Ъ© ШҙШҜ."
msgstr[1] "{0} ЩҶШӘЫҢШ¬ЩҮЩ” Ъ©ШҙвҖҢШҙШҜЩҮ ЩҫШ§Ъ© ШҙШҜ."

