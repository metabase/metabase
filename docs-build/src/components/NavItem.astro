---
import { hrefForPage, urlMatchesSlug } from "../lib/nav";
import type { NavPage } from "../lib/nav";

interface Props {
  page: NavPage;
  currentSlug: string;
  expandedNames: Set<string>;
  depth?: number;
}

const { page, currentSlug, expandedNames, depth = 0 } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const label = page.navName ?? page.name;
const href = hrefForPage(page, base);
const isSelected = urlMatchesSlug(page.url, currentSlug);
const isExpanded = expandedNames.has(page.name);
const hasChildren = !!page.pages?.length;
---

<li class:list={[{ "has-children": hasChildren, expanded: isExpanded }]}>
  {hasChildren ? (
    <div class="nav-row">
      {href ? (
        <a href={href} class:list={[{ selected: isSelected }]}>{label}</a>
      ) : (
        <span class="docs-sidebar-group-label">{label}</span>
      )}
      <button
        type="button"
        class="docs-sidebar-toggle"
        aria-expanded={isExpanded ? "true" : "false"}
        aria-label={`Toggle ${label}`}
      >
        <svg
          width="10"
          height="10"
          viewBox="0 0 16 16"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <polyline points="6 4 10 8 6 12"></polyline>
        </svg>
      </button>
    </div>
  ) : href ? (
    <a href={href} class:list={[{ selected: isSelected }]}>{label}</a>
  ) : (
    <span class="docs-sidebar-group-label">{label}</span>
  )}
  {hasChildren && (
    <ul>
      {page.pages!.map((child) => (
        <Astro.self
          page={child}
          currentSlug={currentSlug}
          expandedNames={expandedNames}
          depth={depth + 1}
        />
      ))}
    </ul>
  )}
</li>
