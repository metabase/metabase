{
  "get": {
    "description": "Get `Field` with ID.",
    "operationId": "get-api-field-id",
    "parameters": [
      {
        "description": "value must be an integer greater than zero.",
        "in": "path",
        "name": "id",
        "required": true,
        "schema": {
          "minimum": 1,
          "type": "integer"
        }
      },
      {
        "in": "query",
        "name": "include_editable_data_model",
        "required": true,
        "schema": {
          "default": false,
          "type": "boolean"
        }
      }
    ],
    "responses": {
      "2XX": {
        "description": "Successful response"
      },
      "4XX": {
        "description": "Client error response"
      },
      "5XX": {
        "description": "Server error response"
      }
    },
    "summary": "GET /api/field/{id}",
    "tags": [
      "/api/field"
    ]
  },
  "put": {
    "description": "Update `Field` with ID.",
    "operationId": "put-api-field-id",
    "parameters": [
      {
        "description": "value must be an integer greater than zero.",
        "in": "path",
        "name": "id",
        "required": true,
        "schema": {
          "minimum": 1,
          "type": "integer"
        }
      }
    ],
    "requestBody": {
      "content": {
        "application/json": {
          "schema": {
            "properties": {
              "caveats": {
                "oneOf": [
                  {
                    "minLength": 1,
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "coercion_strategy": {
                "oneOf": [
                  {
                    "description": "value must be a valid coercion strategy (keyword or string)."
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "description": {
                "oneOf": [
                  {
                    "minLength": 1,
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "display_name": {
                "oneOf": [
                  {
                    "minLength": 1,
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "fk_target_field_id": {
                "oneOf": [
                  {
                    "description": "value must be an integer greater than zero.",
                    "minimum": 1,
                    "type": "integer"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "has_field_values": {
                "oneOf": [
                  {
                    "$ref": "../components/schemas/metabase.lib.schema.metadata..column.has-field-values.json"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "json_unfolding": {
                "oneOf": [
                  {
                    "type": "boolean"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "nfc_path": {
                "oneOf": [
                  {
                    "items": {
                      "minLength": 1,
                      "type": "string"
                    },
                    "type": "array"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "points_of_interest": {
                "oneOf": [
                  {
                    "minLength": 1,
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "semantic_type": {
                "oneOf": [
                  {
                    "description": "value must be a valid field semantic or relation type (keyword or string)."
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "settings": {
                "oneOf": [
                  {
                    "description": "Value must be a map.",
                    "properties": {},
                    "type": "object"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "visibility_type": {
                "oneOf": [
                  {
                    "enum": [
                      "retired",
                      "sensitive",
                      "normal",
                      "hidden",
                      "details-only"
                    ],
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              }
            },
            "type": "object"
          }
        }
      }
    },
    "responses": {
      "2XX": {
        "description": "Successful response"
      },
      "4XX": {
        "description": "Client error response"
      },
      "5XX": {
        "description": "Server error response"
      }
    },
