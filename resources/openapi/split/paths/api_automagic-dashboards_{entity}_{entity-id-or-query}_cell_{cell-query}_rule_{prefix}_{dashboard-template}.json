        "in": "path",
        "name": "entity",
        "required": true,
        "schema": {
          "enum": [
            "adhoc",
            "field",
            "model",
            "question",
            "segment",
            "table",
            "transform"
          ],
          "type": "string"
        }
      },
      {
        "in": "path",
        "name": "entity-id-or-query",
        "required": true,
        "schema": {
