---
/**
 * Page footer: newsletter form + 5-column sitemap + social row. The HTML body
 * lives in `src/data/footer.html` and is imported as a raw string.
 *
 * The newsletter form POSTs directly to Mailchimp; HTML5 form validation
 * handles the email field (no JS dependency). The live status indicator and
 * GitHub star count come from `public/js/status.js` and
 * `public/js/github-stars.js`, loaded by DocsLayout.astro.
 */
import footerHtml from "../data/footer.html?raw";
---

<div class="bootstrap footer-wrap">
  <footer class="body-footer" set:html={footerHtml} />
</div>
