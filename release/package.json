{
  "name": "release-helper",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "run/build.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --outfile=dist/index.cjs --platform=node --target=node16",
    "generate-changelog": "bun generate-changelog.ts",
    "format": "oxfmt --write",
    "release-offline": "tsx release-offline.ts",
    "test:unit": "jest --testPathPattern unit",
    "test:integration": "jest --testPathPattern integration",
    "type-check": "tsc --noEmit"
  },
  "author": "Metabase",
  "license": "AGPL-3.0-or-later",
  "dependencies": {
    "@octokit/rest": "^21.1.1",
    "@slack/web-api": "^7.16.0",
    "dayjs": "^1.11.20",
    "dotenv": "^16.6.1",
    "esbuild": "^0.25.12",
    "node-fetch": "^3.3.2",
    "semver": "^7.8.0",
    "ts-pattern": "^5.9.0",
    "typescript": "^5.9.3",
    "zx": "^8.8.5"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.5",
    "@babel/preset-typescript": "^7.28.5",
    "@types/jest": "^29.5.14",
    "@types/semver": "^7.7.1",
    "jest": "^29.7.0",
    "oxfmt": "^0.38.0"
  },
  "overrides": {
    "form-data": "4.0.6"
  }
}
