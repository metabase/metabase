#: metabase/tracing/settings.clj:60
msgid "Maximum time in milliseconds to wait for a batch export to complete. If the collector is slow or unreachable, the batch is dropped after this timeout."
msgstr "حداکثر زمان به میلی‌ثانیه برای انتظار جهت تکمیل یک خروجی گرفتنِ دسته‌ای. اگر collector کند باشد یا در دسترس نباشد، batch بعد از این تایم‌اوت کنار گذاشته می‌شود."

#: metabase/tracing/settings.clj:20
msgid "OTLP HTTP collector endpoint for trace export (e.g., http://localhost:4318/v1/traces)."
msgstr "اندپوینت collectorِ OTLP HTTP برای خروجی گرفتن از trace (مثلاً http://localhost:4318/v1/traces)."

#: metabase/tracing/settings.clj:76
msgid "Service name reported in traces. Defaults to the hostname."
msgstr "نام سرویسِ گزارش‌شده در traceها. مقدار پیش‌فرض نام میزبان است."

#: metabase/tracing/settings.clj:36
msgid "Log level threshold during traced spans. When a span is active, log events at this level and above bypass per-logger level gates via Log4j2 DynamicThresholdFilter. Requires the filter in log4j2.xml. Valid values: \"INFO\", \"DEBUG\", \"TRACE\"."
msgstr "آستانهٔ سطح لاگ در طول spanهای trace‌شده. وقتی یک span فعال است، رویدادهای لاگ در این سطح و بالاتر، گیت‌های سطحِ هر logger را از طریق Log4j2 DynamicThresholdFilter دور می‌زنند. نیازمند وجود فیلتر در log4j2.xml است. مقادیر معتبر: \"INFO\"، \"DEBUG\"، \"TRACE\"."

#: metabase/tracing/settings.clj:52
msgid "Maximum number of spans queued for export. When the queue is full, new spans are dropped silently. Controls memory usage when the collector is slow or unavailable."
msgstr "حداکثر تعداد spanهای صف‌شده برای خروجی گرفتن. وقتی صف پر باشد، spanهای جدید بدون اطلاع حذف می‌شوند. مصرف حافظه را وقتی collector کند است یا در دسترس نیست کنترل می‌کند."

#: metabase/tracing/settings.clj:12
msgid "Enable OpenTelemetry tracing. When true, spans are exported to the configured OTLP collector."
msgstr "فعال‌سازی رهگیری OpenTelemetry. وقتی true باشد، spanها به collectorِ OTLP پیکربندی‌شده ارسال می‌شوند."

#: metabase/tracing/settings.clj:28
msgid "Comma-separated list of trace groups to enable, or \"all\" for everything."
msgstr "فهرست گروه‌های trace برای فعال‌سازی با جداکنندهٔ ویرگول، یا \"all\" برای همه‌چیز."

#: metabase/tracing/settings.clj:68
msgid "Delay in milliseconds between consecutive batch span exports to the collector."
msgstr "تأخیر به میلی‌ثانیه بین خروجی گرفتنِ متوالی spanهای دسته‌ای به collector."

