{
  "get": {
    "description": "Get all tenants",
    "operationId": "get-api-ee-tenant",
    "parameters": [
      {
        "in": "query",
        "name": "status",
        "required": true,
        "schema": {
          "default": "all",
          "enum": [
            "all",
            "deactivated",
            "active"
          ],
          "type": "string"
        }
      }
    ],
    "responses": {
      "2XX": {
        "content": {
          "application/json": {
            "schema": {
              "additionalProperties": false,
              "properties": {
                "data": {
                  "items": {
                    "additionalProperties": false,
