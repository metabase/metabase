---
/**
 * Top navigation header. The HTML body lives in `src/data/header.html` and is
 * imported as a raw string; per-page behavior (hover-highlight, mobile
 * hamburger, etc.) is in `public/js/main-nav.js`.
 *
 * `/images/...` references inside the markup are rewritten at render time so
 * they resolve against the docs base URL, which varies by version
 * (`/docs/latest`, `/docs/v0.NN`, etc.). Image assets live in `public/images/`.
 */
import headerHtml from "../data/header.html?raw";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const html = headerHtml.replace(/(["'\s])\/images\//g, `$1${base}/images/`);
---

<header class="bootstrap sticky" set:html={html} />
