{
  "$schema": "http://iglucentral.com/schemas/com.snowplowanalytics.self-desc/schema/jsonschema/1-0-0#",
  "description": "Per-mount component usage event for the Metabase Embedding SDK",
  "self": {
    "vendor": "com.metabase",
    "name": "embedding_sdk",
    "format": "jsonschema",
    "version": "1-0-0"
  },
  "type": "object",
  "properties": {
    "component": {
      "description": "Name of the SDK component that was mounted. Null for provider-init beacon events.",
      "type": ["string", "null"],
      "enum": [
        "StaticDashboard",
        "InteractiveDashboard",
        "EditableDashboard",
        "StaticQuestion",
        "InteractiveQuestion",
        "CollectionBrowser",
        "MetabotQuestion",
        null
      ]
    },
    "properties": {
      "description": "Component-specific dimension values captured at mount time. Null for provider-init beacon events.",
      "type": ["object", "null"],
      "properties": {
        "with_title": {
          "description": "Whether the component title is shown.",
          "type": ["boolean", "null"]
        },
        "with_downloads": {
          "description": "Whether downloads are enabled.",
          "type": ["boolean", "null"]
        },
        "with_subscriptions": {
          "description": "Whether subscriptions are enabled.",
          "type": ["boolean", "null"]
        },
        "auto_refresh": {
          "description": "Whether auto-refresh is configured (autoRefreshInterval != null).",
          "type": ["boolean", "null"]
        },
        "enable_entity_navigation": {
          "description": "Whether entity navigation (cross-dashboard drills) is enabled.",
          "type": ["boolean", "null"]
        },
        "is_save_enabled": {
          "description": "Whether saving questions is enabled.",
          "type": ["boolean", "null"]
        },
        "with_alerts": {
          "description": "Whether alerts are enabled.",
          "type": ["boolean", "null"]
        },
        "used": {
          "description": "Presence signal for presence-only components.",
          "type": ["boolean", "null"]
        },
        "layout": {
          "description": "Layout mode for MetabotQuestion.",
          "type": ["string", "null"],
          "enum": ["auto", "sidebar", "stacked", null]
        },
        "id_new": {
          "description": "Whether this is a new blank question (questionId = 'new').",
          "type": ["boolean", "null"]
        },
        "id_new_native": {
          "description": "Whether this is a new native SQL question (questionId = 'new-native').",
          "type": ["boolean", "null"]
        }
      },
      "additionalProperties": false
    },
    "global": {
      "description": "Session-level flags repeated on each event.",
      "type": "object",
      "properties": {
        "auth_method": {
          "description": "Authentication method used for the embedding.",
          "type": "string",
          "enum": ["api_key", "sso", "guest"]
        },
        "sdk_version": {
          "description": "SDK package version string.",
          "type": ["string", "null"],
          "maxLength": 255
        },
        "locale_used": {
          "description": "Whether the consumer set an explicit locale.",
          "type": ["boolean", "null"]
        }
      },
      "required": ["auth_method", "sdk_version", "locale_used"],
      "additionalProperties": false
    }
  },
  "required": ["global"],
  "additionalProperties": false
}
