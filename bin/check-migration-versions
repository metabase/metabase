#!/usr/bin/env bash
set -euo pipefail

# Requires: BASE_REF, CURRENT_VERSION (for master)
# Optional: PR_LABELS (comma-separated, for backport handling)

if [[ -z "${BASE_REF:-}" ]]; then
  echo "ERROR: BASE_REF is not set." >&2
  exit 1
fi

# Ensure origin/${BASE_REF} is reachable
if ! git rev-parse "origin/${BASE_REF}" >/dev/null 2>&1; then
  git fetch origin "$BASE_REF" --depth=1 || { echo "ERROR: Could not resolve origin/${BASE_REF}" >&2; exit 1; }
fi

echo "BASE_REF: ${BASE_REF}"

labels="${PR_LABELS:-}"

# Determine the expected version and constraint
if [[ "$BASE_REF" =~ ^release-x\.([0-9]+)\.x$ ]]; then
  version="${BASH_REMATCH[1]}"
  constraint="<="
elif [[ "$BASE_REF" == "master" ]]; then
  if [[ -z "${CURRENT_VERSION:-}" ]]; then
    echo "ERROR: CURRENT_VERSION is not set." >&2
    exit 1
  fi
  if ! [[ "$CURRENT_VERSION" =~ ^[1-9][0-9]*$ ]]; then
    echo "ERROR: CURRENT_VERSION must be a positive integer, got: '${CURRENT_VERSION}'" >&2
    exit 1
  fi
  echo "CURRENT_VERSION: ${CURRENT_VERSION}"

  backport_count=0
  [[ ",$labels," == *",triple-backport,"* ]] && backport_count=$((backport_count + 1))
  [[ ",$labels," == *",double-backport,"* ]] && backport_count=$((backport_count + 1))
  [[ ",$labels," == *",backport,"* ]] && backport_count=$((backport_count + 1))
  if [[ "$backport_count" -gt 1 ]]; then
    echo "WARNING: Multiple backport labels found — using the most conservative (oldest) version." >&2
  fi

  if [[ ",$labels," == *",triple-backport,"* ]]; then
    version=$((CURRENT_VERSION - 2))
  elif [[ ",$labels," == *",double-backport,"* ]]; then
    version=$((CURRENT_VERSION - 1))
  elif [[ ",$labels," == *",backport,"* ]]; then
    version=$((CURRENT_VERSION))
  else
    version=$((CURRENT_VERSION + 1))
  fi
  constraint="="
else
  echo "Target branch '${BASE_REF}' is not master or a release branch — skipping."
  exit 0
fi

expected_dir=$(printf "%03d" "$version")
echo "Expected directory: ${constraint} ${expected_dir}"
echo ""

# Check that new migration files are in the correct directory
changed_files=$(git diff --name-only --diff-filter=A "origin/${BASE_REF}..HEAD" -- 'resources/migrations/**/*.yaml') || {
  echo "ERROR: git diff failed — could not compare against origin/${BASE_REF}" >&2
  exit 1
}

if [[ -z "$changed_files" ]]; then
  echo "No new migration files changed."
  exit 0
fi

errors=0
while IFS= read -r file; do
  [[ -z "$file" ]] && continue
  dir=$(echo "$file" | sed -n 's|resources/migrations/\([0-9][0-9]*\)/.*|\1|p')
  [[ -z "$dir" ]] && continue
  dir_version=$((10#$dir))
  dir=$(printf "%03d" "$dir_version")

  if [[ "$constraint" == "=" && "$dir_version" -ne "$version" ]] ||
     [[ "$constraint" == "<=" && "$dir_version" -gt "$version" ]]; then
    echo "ERROR: ${file} is in ${dir} but expected ${constraint} ${expected_dir}" >&2
    errors=$((errors + 1))
  fi
done <<< "$changed_files"

if [[ "$errors" -gt 0 ]]; then
  echo "" >&2
  echo "${errors} error(s) found." >&2
  exit 1
fi

echo "All new migration files are in the correct directory."
