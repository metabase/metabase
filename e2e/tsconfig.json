{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "build",
    "baseUrl": "./",
    "types": [
      "cypress",
      "@testing-library/cypress",
      "cypress-real-events",
      "@cypress/grep",
      "../enterprise/frontend/src/embedding-sdk-shared/types/globals.d.ts"
    ],
    "paths": {
      "e2e/*": ["./*"],
      "@metabase/embedding-sdk-react": [
        "../enterprise/frontend/src/embedding-sdk-package/index.ts"
      ],
      "@metabase/embedding-sdk-react/data-app": [
        "../enterprise/frontend/src/embedding-sdk-package/data-app.ts"
      ],
      "*": ["../frontend/src/*"]
    }
  },
  "include": ["**/*"],
  // Data-app fixtures and host apps are standalone SDK apps (built by Vite,
  // typechecked by their own tsconfig) — not part of the e2e TS program.
  "exclude": ["support/assets/data-apps", "embedding-sdk-host-apps"]
}
