{
  "post": {
    "description": "Execute a query and download the result data as a file in the specified format.",
    "operationId": "post-api-dataset-export-format",
    "parameters": [
      {
        "in": "path",
        "name": "export-format",
        "required": true,
        "schema": {
          "$ref": "../components/schemas/metabase.query-processor.schema.export-format.json"
        }
      }
    ],
    "requestBody": {
      "content": {
        "application/json": {
          "schema": {
            "properties": {
              "format_rows": {
                "default": false,
                "type": "boolean"
              },
              "pivot_results": {
                "default": false,
                "type": "boolean"
              },
              "query": {
                "properties": {},
                "type": "object"
              },
              "visualization_settings": {
