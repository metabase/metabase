---
// Renders the Scalar viewer for the OpenAPI spec at /api.json (same origin,
// emitted by src/pages/api.json.ts). docs/api.json is generated by
// `clojure -M:ee:doc api-documentation` and is gitignored — when it's absent
// (e.g. `bun run docs:dev` without running the generator first) we render a
// short notice instead of an empty viewer.
import { hasApiSpec } from "../lib/api-spec";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const scalarVersion = "1.39.1";
const specReady = hasApiSpec();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>API Reference | Metabase Documentation</title>
    <meta name="description" content="The official API documentation for Metabase." />
    <link rel="icon" type="image/svg+xml" href={`${base}/images/favicon.svg`} />
    <style>
      :root {
        --scalar-font: 'Lato', sans-serif;
      }
      html, body { margin: 0; }
      .api-not-generated {
        font-family: 'Lato', sans-serif;
        max-width: 42rem;
        margin: 4rem auto;
        padding: 0 1.5rem;
        line-height: 1.6;
      }
      .api-not-generated code {
        background: #f0f0f0;
        padding: 0.1em 0.35em;
        border-radius: 3px;
      }
    </style>
  </head>
  <body>
    {specReady ? (
      <Fragment>
        <script id="api-reference" data-url={`${base}/api.json`}></script>
        <script
          src={`https://cdn.jsdelivr.net/npm/@scalar/api-reference@${scalarVersion}/dist/browser/standalone.min.js`}
        ></script>
        <link
          rel="stylesheet"
          href={`https://cdn.jsdelivr.net/npm/@scalar/api-reference@${scalarVersion}/dist/style.min.css`}
        />
      </Fragment>
    ) : (
      <div class="api-not-generated">
        <h1>API reference not generated</h1>
        <p>
          The OpenAPI spec (<code>docs/api.json</code>) isn't present in this build.
          Generate it with <code>./bin/generate-docs.sh --api</code> — or run a full
          <code>bun run docs:build</code> — and reload.
        </p>
      </div>
    )}
  </body>
</html>
