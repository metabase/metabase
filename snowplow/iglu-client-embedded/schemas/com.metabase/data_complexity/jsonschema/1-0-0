{
    "$schema": "http://iglucentral.com/schemas/com.snowplowanalytics.self-desc/schema/jsonschema/1-0-0#",
    "description": "Data Complexity Score — one event per (catalog, key) slice.",
    "self": {
        "vendor": "com.metabase",
        "name": "data_complexity",
        "format": "jsonschema",
        "version": "1-0-0"
    },
    "type": "object",
    "required": [
        "event",
        "catalog",
        "key",
        "score",
        "formula_version",
        "parameters"
    ],
    "properties": {
        "event": {
            "description": "Event name.",
            "type": "string",
            "enum": [
                "data_complexity_scoring"
            ],
            "maxLength": 64
        },
        "catalog": {
            "description": "Which catalog of the data layer was scored.",
            "type": "string",
            "enum": [
                "library",
                "universe",
                "metabot"
            ],
            "maxLength": 16
        },
        "key": {
            "description": "Dotted identifier for this slice: `total`, a `<group>.total` rollup, or a `<group>.<component>` leaf. Free-form so new keys can be added without a schema bump.",
            "type": "string",
            "maxLength": 64
        },
        "score": {
            "description": "Weighted score for this key. Null when the sub-score (or any sub-score it aggregates) couldn't be computed.",
            "type": [
                "integer",
                "null"
            ],
            "minimum": 0,
            "maximum": 2147483647
        },
        "measurement": {
            "description": "Raw pre-score measurement (absent on aggregates; null on uncomputed leaves). Number, not integer, to future-proof density-style metrics.",
            "type": [
                "number",
                "null"
            ],
            "minimum": 0,
            "maximum": 9007199254740991
        },
        "error": {
            "description": "Failure message on the originating leaf when its sub-score couldn't be computed; aggregates carry null `score` instead.",
            "type": [
                "string",
                "null"
            ],
            "maxLength": 1024
        },
        "formula_version": {
            "description": "Scoring formula version; bumps on breaking changes. Kept top-level so cross-version filters are a single column.",
            "type": "integer",
            "minimum": 1,
            "maximum": 2147483647
        },
        "parameters": {
            "description": "Scoring inputs that are likely to evolve (tunables, embedder identity). Sorted-key JSON so the string form is stable for SQL group-by; Metabase transforms can break out individual keys without a schema bump.",
            "type": "object",
            "additionalProperties": true
        }
    }
}
