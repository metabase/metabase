      {
        "in": "query",
        "name": "latField",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      {
        "in": "query",
        "name": "lonField",
        "required": true,
        "schema": {
          "type": "string"
        }
      }
    ],
    "responses": {
      "2XX": {
