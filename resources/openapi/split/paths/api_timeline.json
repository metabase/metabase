{
  "get": {
    "description": "Fetch a list of `Timeline`s. Can include `archived=true` to return archived timelines.",
    "operationId": "get-api-timeline",
    "parameters": [
      {
        "in": "query",
        "name": "include",
        "required": false,
        "schema": {
          "$ref": "../components/schemas/metabase.timeline.api.timeline.include.json"
        }
      },
      {
        "in": "query",
        "name": "archived",
        "required": true,
        "schema": {
          "default": false,
          "type": "boolean"
        }
      }
    ],
    "responses": {
      "2XX": {
        "content": {
          "application/json": {
            "schema": {
              "items": {
                "$ref": "../components/schemas/metabase.timeline.api.timeline.Timeline.json"
              },
              "type": "array"
            }
          }
        },
        "description": "Successful response"
      },
      "4XX": {
        "description": "Client error response"
      },
      "5XX": {
        "description": "Server error response"
      }
    },
    "summary": "GET /api/timeline",
    "tags": [
      "/api/timeline"
    ]
  },
  "post": {
    "description": "Create a new [[Timeline]].",
    "operationId": "post-api-timeline",
    "parameters": [],
    "requestBody": {
      "content": {
        "application/json": {
          "schema": {
            "properties": {
              "archived": {
                "oneOf": [
                  {
                    "type": "boolean"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "collection_id": {
                "oneOf": [
                  {
                    "description": "value must be an integer greater than zero.",
                    "minimum": 1,
                    "type": "integer"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "default": {
                "oneOf": [
                  {
                    "type": "boolean"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "description": {
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "icon": {
                "oneOf": [
                  {
                    "enum": [
                      "star",
                      "cake",
                      "mail",
                      "warning",
                      "bell",
                      "cloud"
                    ],
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "name": {
                "minLength": 1,
                "type": "string"
              }
            },
            "required": [
              "name"
            ],
            "type": "object"
          }
        }
      }
    },
    "responses": {
      "2XX": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "../components/schemas/metabase.timeline.api.timeline.Timeline.json"
            }
          }
        },
        "description": "Successful response"
      },
      "4XX": {
        "description": "Client error response"
      },
      "5XX": {
        "description": "Server error response"
      }
    },
    "summary": "POST /api/timeline",
    "tags": [
      "/api/timeline"
    ]
  }
}