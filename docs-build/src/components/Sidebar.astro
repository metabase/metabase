---
import { getNav } from "../lib/nav";
import type { NavPage } from "../lib/nav";
import NavItem from "./NavItem.astro";

interface Props {
  currentSlug: string;
  trail: NavPage[];
}

const { currentSlug, trail } = Astro.props;
const nav = getNav();
const expandedNames = new Set(trail.map((t) => t.name));
---

<nav class="docs-sidebar" aria-label="Documentation">
  {nav.categories.map((category) => (
    <div class="docs-sidebar-category">
      <h5>{category.name}</h5>
      <ul>
        {category.pages.map((page) => (
          <NavItem
            page={page}
            currentSlug={currentSlug}
            expandedNames={expandedNames}
          />
        ))}
      </ul>
    </div>
  ))}
</nav>
