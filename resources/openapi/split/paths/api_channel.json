{
  "get": {
    "description": "Get all channels",
    "operationId": "get-api-channel",
    "parameters": [],
    "requestBody": {
      "content": {
        "application/json": {
          "schema": {
            "properties": {
              "include_inactive": {
                "default": false,
                "oneOf": [
                  {
                    "type": "boolean"
                  },
                  {
                    "type": "null"
                  }
                ]
              }
            },
            "type": "object"
          }
        }
      }
    },
    "responses": {
      "2XX": {
        "description": "Successful response"
      },
      "4XX": {
        "description": "Client error response"
      },
      "5XX": {
        "description": "Server error response"
      }
    },
    "summary": "GET /api/channel",
    "tags": [
      "/api/channel"
    ]
  },
  "post": {
    "description": "Create a channel",
    "operationId": "post-api-channel",
    "parameters": [],
    "requestBody": {
      "content": {
        "application/json": {
          "schema": {
            "properties": {
              "active": {
                "default": true,
                "oneOf": [
                  {
                    "type": "boolean"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "description": {
                "oneOf": [
                  {
                    "minLength": 1,
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "details": {
                "properties": {},
                "type": "object"
              },
              "name": {
                "minLength": 1,
                "type": "string"
              },
              "type": {
                "description": "Must be a namespaced channel. E.g: channel/http"
              }
            },
            "required": [
              "name",
              "type",
              "details"
            ],
            "type": "object"
          }
        }
      }
    },
    "responses": {
      "2XX": {
        "description": "Successful response"
      },
      "4XX": {
        "description": "Client error response"
      },
      "5XX": {
        "description": "Server error response"
      }
    },
    "summary": "POST /api/channel",
    "tags": [
      "/api/channel"
    ]
  }
}