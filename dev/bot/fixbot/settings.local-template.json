{
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": true,
    "filesystem": {
      "allowWrite": [".", "{{pwd}}", "~/.m2", "~/.gitlibs", "~/.deps.clj", "~/.local/state/workmux", "~/.cache/workmux", "{{tmpdir}}", "/tmp", "/private/tmp", "~/Library/Caches/ms-playwright", "~/Library/Application Support/Google/Chrome"],
      "allowRead": [".", "{{pwd}}", "~/.m2", "~/.gitlibs", "~/.deps.clj", "~/.local/state/workmux", "~/.cache/workmux", "{{tmpdir}}", "/tmp", "/private/tmp", "~/Library/Caches/ms-playwright", "~/Library/Application Support/Google/Chrome"]
    },
    "excludedCommands": ["docker"],
    "network": {
      "allowLocalBinding": true,
      "allowAllUnixSockets": true,
      "allowedDomains": ["github.com", "api.github.com", "*.blob.core.windows.net", "api.linear.app"]
    }
  },
  "permissions": {
    "allow": [
      "Edit",
      "Write",
      "Skill",
      "Grep",
      "Bash(*)",
      "mcp__playwright__*",
      "WebFetch(domain:linear.app)",
      "WebFetch(domain:metabase.com)"
    ]
  },
  "skipDangerousModePermissionPrompt": true
}
