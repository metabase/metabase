          "$ref": "../components/schemas/metabase.lib.schema.id.dashboard.json"
        }
      },
      {
        "in": "path",
        "name": "dashcard-id",
        "required": true,
        "schema": {
          "$ref": "../components/schemas/metabase.lib.schema.id.dashcard.json"
        }
      },
      {
        "in": "path",
        "name": "card-id",
        "required": true,
        "schema": {
          "$ref": "../components/schemas/metabase.lib.schema.id.card.json"
